        "templateCss": ".card {\n font-family: \"ヒラギノ角ゴ Pro W3\", \"Hiragino Kaku Gothic Pro\", \"Noto Sans JP\", \"Noto Sans CJK JP\", Osaka, \"メイリオ\", Meiryo, \"ＭＳ Ｐゴシック\", \"MS PGothic\", \"MS UI Gothic\", sans-serif;\n font-size: 44px;\n text-align: center;\n}\n\nimg {\nmax-width: 300px;\nmax-height: 250px;\n}\n\n.mobile img {\nmax-width: 50vw;\n}\n\n\/* This part defines the bold color. *\/\nb{color: #5586cd}",
        "extraAnswerField": "Word Meaning,Sentence Meaning",
        "overlayQuestionField": "",
        "frontTemplate": "<div lang=\"ja\">\n{{Word}}\n<div style='font-size: 25px;'>{{Sentence}}<\/div>\n<\/div>",
